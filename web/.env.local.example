# Gemini (Google) — used for storyboard scripting AND video when provider=gemini (Veo 3)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — used for video when provider=chatgpt (Sora 2)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# HiggsField — used for video when provider=higgsfield
# https://cloud.higgsfield.ai/
HF_KEY=
# HF_API_KEY=
# HF_API_SECRET=

# Optional: Supabase (enables sign-in + cross-session memory).
# Get these from https://supabase.com/ → your project → Project Settings → API.
# Leave blank to keep the app anonymous (no sign-in, no history sidebar).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.5-pro
VEO_MODEL=veo-3.0-generate-001
SORA_MODEL=sora-2

# HiggsField endpoint (image-to-video only — HF has no text-to-video models).
# Browse the full catalog at https://docs.higgsfield.ai/ — other paths include
# kling-video/v2.1/pro/image-to-video, etc.
HF_IMAGE_TO_VIDEO_ENDPOINT=higgsfield-ai/dop/standard

# Seedance routes through HiggsField (uses HF_KEY for auth). Supports both
# text-to-video and image-to-video. Override either path if HiggsField uses
# different catalog strings on your account.
SEEDANCE_TEXT_TO_VIDEO_ENDPOINT=bytedance/seedance/v2/text-to-video
SEEDANCE_IMAGE_TO_VIDEO_ENDPOINT=bytedance/seedance/v1/pro/image-to-video
