# Gemini (Google) — used for storyboard scripting AND for video when --provider=gemini (Veo 3)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — used for video when --provider=chatgpt (Sora 2)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# HiggsField Cloud — used for video when --provider=higgsfield
# Get credentials at https://cloud.higgsfield.ai/
# Either set the combined key (key:secret) OR the split pair below.
HF_KEY=
# HF_API_KEY=
# HF_API_SECRET=

# --- Optional model overrides ---

# Gemini model used by the storyboard writer
GEMINI_MODEL=gemini-2.5-pro

# Veo model used when --provider=gemini
VEO_MODEL=veo-3.0-generate-001

# Sora model used when --provider=chatgpt
SORA_MODEL=sora-2

# Default HiggsField endpoints used when --provider=higgsfield.
# See https://cloud.higgsfield.ai/ for the full model catalog.
HF_TEXT_TO_VIDEO_ENDPOINT=higgsfield/dop/v1/text-to-video
HF_IMAGE_TO_VIDEO_ENDPOINT=higgsfield/dop/v1/image-to-video
